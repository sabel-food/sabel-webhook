# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Formspree webhook secret — get from Formspree form Settings → Webhooks
# Leave blank during initial testing; add once working
FORMSPREE_SECRET=

# Email addresses to receive the generated documents
EMAIL_PRIMARY=info@sabelcustomersuccess.com
EMAIL_CC=project-admin@sabelcustomersuccess.com

# Sender address — must be a verified domain in Resend
# Use 'onboarding@resend.dev' for initial testing before domain is verified
EMAIL_FROM=noreply@sabelcustomersuccess.com
